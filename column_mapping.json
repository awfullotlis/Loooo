  "composite_keys": {
    "广州": {
      "parent": "港澳",
      "exclude": ["港澳组"],
      "sum_fields": ["池子数", "月初续费人数", "累计续费人数"],
      "derived_fields": {
        "目前续费率": { "formula": "divide", "numerator": "累计续费人数", "denominator": "池子数" },
        "月初续费率": { "formula": "divide", "numerator": "月初续费人数", "denominator": "池子数" },
        "月累计涨幅": { "formula": "subtract", "a": "目前续费率", "b": "月初续费率" },
        "当前续费率加总": { "formula": "divide", "numerator": "累计续费人数", "denominator": "池子数" },
        "当前续费率": { "formula": "divide", "numerator": "累计续费人数", "denominator": "池子数" },
